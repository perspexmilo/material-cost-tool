// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Supplier {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  materials Material[]
  aliases   SupplierAlias[]

  @@map("suppliers")
}

model Material {
  id           String   @id @default(cuid())
  description  String
  category     String   // e.g. "Wood", "Plastic", "Accessories"
  typeFinish   String   @map("type_finish") // e.g. "MDF", "Plywood", "Acrylic"
  thicknessMm  Decimal  @map("thickness_mm") @db.Decimal(6, 2)
  widthMm      Decimal  @map("width_mm") @db.Decimal(8, 2)
  heightMm     Decimal  @map("height_mm") @db.Decimal(8, 2)
  supplierId   String   @map("supplier_id")
  costPerSheet Decimal  @map("cost_per_sheet") @db.Decimal(10, 2)
  updateSource String   @default("manual") @map("update_source") // "manual" | "email-parse" | "import"
  lastUpdatedAt DateTime @default(now()) @map("last_updated_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  markupMultiplier  Decimal?  @map("markup_multiplier") @db.Decimal(5, 3)

  // Magento integration fields
  magentoSku        String?  @unique @map("magento_sku")
  magentoName       String?  @map("magento_name")
  magentoEntityId   Int?     @unique @map("magento_entity_id")
  variantType       String?  @map("variant_type") // e.g. "Kronospan", "FINSA 12Twenty"

  supplier      Supplier        @relation(fields: [supplierId], references: [id])
  costHistory   CostHistory[]
  stagedChanges StagedChange[]

  @@index([category])
  @@index([typeFinish])
  @@index([supplierId])
  @@index([magentoSku])
  @@map("materials")
}

model CostHistory {
  id            String    @id @default(cuid())
  materialId    String    @map("material_id")
  previousCost  Decimal   @map("previous_cost") @db.Decimal(10, 2)
  newCost       Decimal   @map("new_cost") @db.Decimal(10, 2)
  changedAt     DateTime  @default(now()) @map("changed_at")
  effectiveDate DateTime? @map("effective_date")
  updateSource  String    @map("update_source") // "manual" | "email-parse" | "import" | "staged"
  notes         String?

  material Material @relation(fields: [materialId], references: [id], onDelete: Cascade)

  @@index([materialId])
  @@index([changedAt])
  @@map("cost_history")
}

model StagedChange {
  id            String   @id @default(cuid())
  materialId    String   @map("material_id")
  proposedCost  Decimal  @map("proposed_cost") @db.Decimal(10, 2)
  currentCost   Decimal  @map("current_cost") @db.Decimal(10, 2)
  effectiveDate DateTime @map("effective_date")
  updateSource  String   @default("email-parse") @map("update_source")
  notes         String?
  createdAt     DateTime @default(now()) @map("created_at")

  material Material @relation(fields: [materialId], references: [id], onDelete: Cascade)

  @@index([effectiveDate])
  @@index([materialId])
  @@map("staged_changes")
}

model SupplierAlias {
  id         String   @id @default(cuid())
  rawText    String   @unique @map("raw_text")
  materialId String   @map("material_id")
  supplierId String?  @map("supplier_id")
  createdAt  DateTime @default(now()) @map("created_at")

  supplier Supplier? @relation(fields: [supplierId], references: [id])

  @@index([rawText])
  @@map("supplier_aliases")
}

model ParserContext {
  id        String   @id @default(cuid())
  hint      String
  createdAt DateTime @default(now()) @map("created_at")

  @@map("parser_context")
}

// ─── Competitor Price Monitor ────────────────────────────────────────────────

model CompetitorBasketItem {
  id          String   @id @default(cuid())
  name        String   // e.g. "3mm Clear Acrylic"
  category    String   // e.g. "Plastic"
  magentoEntityId Int?  @map("magento_entity_id") // entity_id of the equivalent Cut My variant
  widthMm     Int      @map("width_mm")
  heightMm    Int      @map("height_mm")
  thicknessMm Decimal  @map("thickness_mm") @db.Decimal(6, 2)
  colour      String?
  materialRef String?  @map("material_ref")
  active      Boolean  @default(true)
  createdAt   DateTime @default(now()) @map("created_at")

  prices CompetitorPrice[]

  @@map("competitor_basket_items")
}

model CompetitorRun {
  id         String   @id @default(cuid())
  competitor String   // e.g. "simply-plastics"
  runAt      DateTime @default(now()) @map("run_at")
  status     String   @default("success") // "success" | "partial" | "failed"
  notes      String?

  prices CompetitorPrice[]

  @@index([competitor])
  @@index([runAt])
  @@map("competitor_runs")
}

model CompetitorPrice {
  id           String   @id @default(cuid())
  runId        String   @map("run_id")
  basketItemId String   @map("basket_item_id")
  priceGbp     Decimal? @map("price_gbp") @db.Decimal(10, 2)
  pricePerM2   Decimal? @map("price_per_m2") @db.Decimal(10, 2)
  url          String?
  rawValue     String?  @map("raw_value")

  run        CompetitorRun        @relation(fields: [runId], references: [id], onDelete: Cascade)
  basketItem CompetitorBasketItem @relation(fields: [basketItemId], references: [id])

  @@index([runId])
  @@index([basketItemId])
  @@map("competitor_prices")
}
